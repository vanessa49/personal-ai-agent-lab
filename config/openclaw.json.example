{
  "meta": {
    "lastTouchedVersion": "2026.3.11",
    "lastTouchedAt": "2026-03-20T12:00:00.000Z"
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://<OLLAMA_HOST>:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "qwen3.5:9b-q4_K_M",
            "name": "Qwen3.5 9B",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 },
            "contextWindow": 32768,
            "maxTokens": 32768
          },
          {
            "id": "qwen2.5:7b-instruct-q4_K_M",
            "name": "Qwen2.5 7B",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 },
            "contextWindow": 32768,
            "maxTokens": 32768
          },
          {
            "id": "bge-m3",
            "name": "BGE-M3 Embedding",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0 },
            "contextWindow": 8192,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen3.5:9b-q4_K_M",
        "fallbacks": ["ollama/qwen2.5:7b-instruct-q4_K_M"]
      },
      "workspace": "/ai-agent",
      "memorySearch": {
        "enabled": true,
        "provider": "ollama",
        "model": "bge-m3",
        "sources": ["memory", "sessions"],
        "extraPaths": ["/ai-agent/skills"],
        "remote": {
          "baseUrl": "http://<OLLAMA_HOST>:11434",
          "apiKey": "ollama-local"
        },
        "store": {
          "driver": "sqlite",
          "path": "/home/node/.openclaw/memory/{agentId}.sqlite",
          "vector": { "enabled": true }
        },
        "chunking": { "tokens": 512, "overlap": 50 },
        "query": {
          "maxResults": 10,
          "minScore": 0.5,
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3
          }
        },
        "sync": {
          "onSessionStart": true,
          "onSearch": true,
          "watch": true
        }
      },
      "subagents": {
        "model": { "primary": "ollama/qwen2.5:7b-instruct-q4_K_M" },
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "archiveAfterMinutes": 60
      },
      "compaction": { "mode": "safeguard" },
      "elevatedDefault": "off"
    }
  },
  "memory": { "backend": "builtin", "citations": "auto" },
  "cron": {
    "enabled": true,
    "store": "/home/node/.openclaw/cron/jobs.json"
  },
  "tools": {
    "profile": "coding",
    "exec": { "host": "gateway", "security": "full", "timeoutSec": 300 },
    "fs": { "workspaceOnly": false },
    "web": {
      "search": { "enabled": false },
      "fetch": { "enabled": true }
    },
    "allow": ["read","write","edit","exec","web_fetch","memory_search","memory_get","sessions_list","sessions_history","sessions_send","sessions_spawn","cron"],
    "deny": ["browser","web_search"],
    "elevated": { "enabled": false }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "load": { "extraDirs": ["/ai-agent/hooks"] }
    }
  },
  "channels": {
    "discord": { "enabled": false },
    "feishu": {
      "enabled": false,
      "domain": "feishu",
      "connectionMode": "websocket",
      "dmPolicy": "pairing",
      "groupPolicy": "open",
      "requireMention": false,
      "accounts": {
        "default": {
          "enabled": true,
          "name": "<BOT_NAME>",
          "appId": "<FEISHU_APP_ID>",
          "appSecret": "<FEISHU_APP_SECRET>",
          "botName": "<BOT_DISPLAY_NAME>"
        }
      },
      "tools": { "doc": true, "chat": true, "wiki": true, "drive": true, "perm": false },
      "streaming": true,
      "markdown": { "mode": "native", "tableMode": "native" }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "<GENERATE_WITH: openssl rand -hex 24>"
    },
    "controlUi": { "enabled": true },
    "tools": { "allow": ["sessions_spawn","cron"] }
  },
  "plugins": {
    "entries": {
      "feishu": { "enabled": false },
      "training-sample-generator": {
        "enabled": true,
        "config": {
          "scoreThreshold": 7,
          "samplesTrigger": 500,
          "daysSinceLastTrain": 30,
          "minNewSamples": 100
        }
      },
      "memory-compressor": {
        "enabled": true,
        "config": {
          "conversationTurnThreshold": 20,
          "logLineThreshold": 100,
          "keepRecentLogs": 20
        }
      }
    },
    "load": {
      "paths": [
        "/ai-agent/plugins/tool-logger",
        "/ai-agent/plugins/safe-delete-enforcer",
        "/ai-agent/plugins/qdrant-auto-checker",
        "/ai-agent/plugins/task-logger",
        "/ai-agent/plugins/training-sample-generator",
        "/ai-agent/plugins/memory-compressor"
      ]
    }
  }
}
